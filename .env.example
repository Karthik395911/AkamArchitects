# Copy this file to .env and fill in the values you want to enable.
# All of these are optional - the site builds and runs fine without any of them.

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_ID=

# Microsoft Clarity project ID
PUBLIC_CLARITY_ID=

# Formspree form ID - enables the Contact page enquiry form
# Create a form at https://formspree.io and use the ID from your form's endpoint
PUBLIC_FORMSPREE_ID=
