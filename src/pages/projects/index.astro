---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import Reveal from "../../components/Reveal.tsx";
import { projectCategories } from "../../lib/site";

const page = await getEntry("pages", "projects");
const { eyebrow, heading, intro } = page?.data ?? {};

const allProjects = await getCollection("projects");
const projects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.featuredOrder - b.data.featuredOrder);

const filters = ["All", ...projectCategories] as const;
---

<Layout
  title="Projects"
  description="A selection of flagship residential, commercial, interior, hospitality, and institutional projects by AKAM Architects & Construction."
>
  <section class="container-page pb-10 pt-36 md:pt-44">
    {
      heading && (
        <Reveal client:visible>
          {eyebrow && <p class="text-xs uppercase tracking-[0.3em] text-accent">{eyebrow}</p>}
          <h1 class="mt-3 max-w-2xl text-balance font-heading text-4xl tracking-tight md:text-6xl">
            {heading}
          </h1>
          {intro && projects.length > 0 && (
            <p class="mt-5 max-w-lg leading-relaxed text-stone">
              {projects.length} {intro}
            </p>
          )}
        </Reveal>
      )
    }

    {
      projects.length > 0 && (
        <div
          id="project-filters"
          class="mt-10 flex flex-wrap gap-3 border-y border-hairline py-6"
          role="group"
          aria-label="Filter projects by category"
        >
          {filters.map((filter) => (
            <button
              type="button"
              data-filter={filter}
              aria-pressed={filter === "All"}
              class="filter-btn rounded-full border border-hairline px-4 py-2 text-sm tracking-wide transition-colors data-[active=true]:border-ink data-[active=true]:bg-ink data-[active=true]:text-paper"
              data-active={filter === "All"}
            >
              {filter}
            </button>
          ))}
        </div>
      )
    }
  </section>

  <section class="container-page py-16">
    <div id="project-grid" class="grid gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project, index) => (
          <div data-category={project.data.category} class="project-item">
            <Reveal client:visible delay={Math.min(index % 3, 2) * 0.08}>
              <ProjectCard project={project} priority={index < 3} />
            </Reveal>
          </div>
        ))
      }
    </div>
    <p id="empty-state" class="hidden py-16 text-center text-stone">
      No projects in this category yet - check back soon.
    </p>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLDivElement>(".project-item");
  const emptyState = document.getElementById("empty-state");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.dataset.active = String(b === btn);
        b.setAttribute("aria-pressed", String(b === btn));
      });

      let visibleCount = 0;
      items.forEach((item) => {
        const match = filter === "All" || item.dataset.category === filter;
        item.classList.toggle("hidden", !match);
        if (match) visibleCount++;
      });

      emptyState?.classList.toggle("hidden", visibleCount > 0);
    });
  });
</script>
