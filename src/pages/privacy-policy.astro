---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("legal", "privacy-policy");
if (!entry) throw new Error("Missing content entry: src/content/legal/privacy-policy.md");
const { title, lastUpdated } = entry.data;
const { Content } = await render(entry);
---

<Layout
  title={title}
  description="How AKAM Architects & Construction collects, uses, and protects your information."
>
  <section class="container-page max-w-3xl py-36 md:py-44">
    <p class="text-xs uppercase tracking-[0.3em] text-accent">Legal</p>
    <h1 class="mt-3 font-heading text-4xl tracking-tight md:text-5xl">{title}</h1>
    <p class="mt-4 text-sm text-stone">Last updated: {lastUpdated}</p>

    <div class="prose-legal mt-12 max-w-none leading-relaxed text-stone">
      <Content />
    </div>
  </section>
</Layout>

<style>
  .prose-legal :global(h2) {
    margin-top: 2.5rem;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-ink);
  }
  .prose-legal :global(h2:first-child) {
    margin-top: 0;
  }
  .prose-legal :global(p) {
    margin-top: 0.75rem;
  }
  .prose-legal :global(a) {
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .prose-legal :global(a:hover) {
    color: var(--color-accent);
  }
</style>
