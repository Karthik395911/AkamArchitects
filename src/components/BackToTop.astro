<button
  id="back-to-top"
  type="button"
  aria-label="Back to top"
  class="fixed bottom-6 left-6 z-50 flex h-11 w-11 translate-y-4 items-center justify-center rounded-full border border-hairline bg-paper text-ink opacity-0 shadow-sm transition-all duration-300 ease-out pointer-events-none hover:border-ink focus-visible:pointer-events-auto"
>
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
    <path d="M8 13V3M3 7l5-5 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</button>

<script>
  const btn = document.getElementById("back-to-top");

  function toggleVisibility() {
    if (!btn) return;
    const visible = window.scrollY > 640;
    btn.classList.toggle("opacity-0", !visible);
    btn.classList.toggle("translate-y-4", !visible);
    btn.classList.toggle("pointer-events-none", !visible);
    btn.classList.toggle("pointer-events-auto", visible);
  }

  btn?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  document.addEventListener("scroll", toggleVisibility, { passive: true });
  toggleVisibility();
</script>
