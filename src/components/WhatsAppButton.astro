---
import type { SiteSettings } from "../lib/settings";

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;

const message = encodeURIComponent(
  "Hello AKAM Architects, I'd like to enquire about a project.",
);
const href = `https://wa.me/${settings.whatsapp}?text=${message}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat with us on WhatsApp"
  class="fixed bottom-6 right-6 z-50 flex h-13 w-13 items-center justify-center rounded-full bg-accent text-ink shadow-lg transition-transform duration-300 ease-out hover:scale-105"
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M17.472 14.382c-.297-.149-1.758-.868-2.03-.967-.273-.099-.472-.148-.67.15-.198.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.29.173-1.413-.074-.124-.272-.198-.57-.347z"
    />
    <path
      d="M12.004 2C6.486 2 2 6.486 2 12.004c0 1.887.523 3.729 1.514 5.335L2 22l4.788-1.492A9.96 9.96 0 0 0 12.004 22C17.522 22 22 17.514 22 12.004 22 6.486 17.522 2 12.004 2zm0 18.09a8.06 8.06 0 0 1-4.116-1.13l-.295-.176-2.842.886.9-2.77-.192-.285a8.075 8.075 0 0 1-1.27-4.33c0-4.46 3.63-8.09 8.11-8.09 4.462 0 8.09 3.63 8.09 8.09 0 4.462-3.628 8.09-8.09 8.09z"
